rules_version = '2';

// Lumi — Firestore security rules.
// Each user can read/write only their own data under users/{uid}/…
// The recursive wildcard covers the web sync document at
// users/{uid}/sync/snapshot as well as any other per-user subcollections.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
